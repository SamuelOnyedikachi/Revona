{
  "name": "revora-server",
  "version": "1.0.0",
  "description": "ReVora backend — Node/Express/MongoDB/Socket.IO",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "seed:pilot": "node scripts/seedPilot.js",
    "seed:clear": "node -e \"require(\"dotenv\").config(); const mongoose = require(\"mongoose\"); mongoose.connect(process.env.MONGO_URI).then(() => mongoose.connection.dropDatabase()).then(() => { console.log(\"DB cleared\"); process.exit(0); })\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "mongodb-memory-server": "^9.1.6"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  }
}