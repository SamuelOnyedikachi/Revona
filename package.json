{
  "name": "revora",
  "version": "1.0.0",
  "description": "Circular economy platform for food waste valorisation",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "dev": "concurrently \"pnpm run server\" \"pnpm run client\"",
    "server": "pnpm -C server dev",
    "client": "pnpm -C client start",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
